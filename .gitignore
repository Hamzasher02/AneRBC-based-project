# --- Dataset & Outputs (never commit large files) ---
# Rule: ignore directory CONTENTS but allow .gitkeep anchor files.
# Using dir/* (one-level glob) + negation works; dir/ does NOT support negation.
data/raw/*
!data/raw/.gitkeep
data/processed/*
!data/processed/.gitkeep
data/splits/*
!data/splits/.gitkeep
checkpoints/*
!checkpoints/.gitkeep
outputs/figures/*
!outputs/figures/.gitkeep
outputs/reports/*
!outputs/reports/.gitkeep

# --- Python cache ---
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
dist/
build/
.eggs/

# --- Jupyter ---
.ipynb_checkpoints/
*.ipynb_checkpoints

# --- Virtual environments ---
venv/
env/
.venv/
.env/
ENV/

# --- IDE / OS ---
.vscode/
.idea/
*.DS_Store
Thumbs.db

# --- Logs & temp ---
*.log
*.tmp
*.bak
